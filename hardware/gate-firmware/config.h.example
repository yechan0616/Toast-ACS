#pragma once

// 통신 모드예요. 0이면 USB 유선(맥북 브리지 경유, 기본), 1이면 Wi-Fi로 직접 접속해요.
#define USE_WIFI 0

// 아래 값은 Wi-Fi 모드(USE_WIFI 1)에서만 써요.
// USB 모드는 서버 주소·게이트 키를 맥북 브리지(hardware/bridge)가 맡아요.
// 브리지 기본값이 로컬 백엔드(localhost:8080, dev-gate-key-change-me)와 같아서
// 로컬 시연에서는 이 파일을 그대로 둬도 돼요.

#define WIFI_SSID "hotspot-name"
#define WIFI_PASS "password"

// 폴백 SSID예요(예: 다른 팀원 핫스팟). 안 쓰면 빈 문자열로 두면 건너뛰어요.
#define WIFI_SSID_FALLBACK ""
#define WIFI_PASS_FALLBACK ""

#define API_BASE "https://api.acs.example.com"
#define GATE_KEY "change-me"
